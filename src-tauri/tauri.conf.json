{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Wavely",
  "version": "1.0.0",
  "identifier": "com.wavely.desktop",
  "build": {
    "frontendDist": "../tauri-dist",
    "beforeDevCommand": "node scripts/prepare-tauri.js",
    "beforeBuildCommand": "node scripts/prepare-tauri.js"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Wavely",
        "url": "index.html",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 640,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "publisher": "Asmit Sharma",
    "homepage": "https://wavely.asmit.tech",
    "copyright": "Copyright (c) 2026 Asmit Sharma",
    "licenseFile": "../LICENSE.txt",
    "shortDescription": "A glass-style desktop music player.",
    "longDescription": "Wavely is a glass-style desktop music player with lyrics, playlists, artist search, thumbnails, visualizer, and a custom transparent Windows experience.",
    "icon": [
      "../build/icon.ico"
    ],
    "windows": {
      "nsis": {
        "headerImage": "../build/installer-header.bmp",
        "sidebarImage": "../build/installer-sidebar.bmp",
        "installerIcon": "../build/icon.ico",
        "uninstallerIcon": "../build/icon.ico",
        "installMode": "both",
        "languages": [
          "English"
        ],
        "displayLanguageSelector": false,
        "compression": "lzma",
        "startMenuFolder": "Wavely"
      }
    }
  }
}
