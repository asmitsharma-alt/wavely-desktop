{
  "name": "wavely-desktop",
  "version": "1.0.0",
  "description": "Wavely Apple Music style desktop player",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win dir",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.wavely.desktop",
    "productName": "Wavely",
    "asar": false,
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "build/icon.ico"
    ],
    "win": {
      "target": "dir",
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    }
  }
}
